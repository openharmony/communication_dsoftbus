@!namespace("@ohos.distributedSoftBus.conversation", "conversation")

@!sts_inject("""
static { loadLibraryWithPermissionCheck("conversation_taihe_native.z", "@ohos.distributedSoftBus.conversation") }
 """)
@!sts_inject_into_module("import { Callback } from '@ohos.base';")

struct DeviceNodeInfo {
    networkId: String;
    deviceName: String;
    deviceTypeId: i32;
    nearby: bool;
    udid: String;
}

function GetTrustedDevices(): Array<DeviceNodeInfo>;

@gen_promise("postConversationData")
function PostConversationDataAsync(deviceId: String, bundleName: String, abilityName: String,
    msg: @arraybuffer Array<u8>): void;

function RegisterConversationListener(bundleName: String, abilityName: String,
    callback: (networkId: String, msg: @arraybuffer Array<u8>) => void): void;

function UnregisterConversationListener(bundleName: String, abilityName: String): void;
