import("../../../dsoftbus.gni")
 
ohos_shared_library("conversation") {
 
  sources = []
  deps = []
  external_deps = []
  if (!dsoftbus_feature_compile_guard) {
    include_dirs = [
      "$dsoftbus_root_path/interfaces/kits/bus_center",
      "$dsoftbus_sdk_path/napi/agent_communication/include",
    ]
 
    sources += [
      "$dsoftbus_sdk_path/napi/agent_communication/src/napi_agent_communication.cpp",
      "$dsoftbus_sdk_path/napi/agent_communication/src/napi_agent_communication_utils.cpp",
    ]
 
    deps += [
      "$dsoftbus_dfx_path:softbus_dfx",
      "$dsoftbus_root_path/adapter:softbus_adapter",
      "$dsoftbus_root_path/core/common:softbus_utils",
      "$dsoftbus_root_path/sdk:softbus_client",
      "$dsoftbus_dfx_path/dumper/legacy:softbus_dfx_dump",
    ]
    
    external_deps = [
      "c_utils:utils",
      "access_token:libaccesstoken_sdk",
      "access_token:libtokenid_sdk",
      "ipc:ipc_core",
      "bounds_checking_function:libsec_shared",
      "hilog:libhilog",
      "napi:ace_napi",
    ]
  } else {
    include_dirs = [
      "$dsoftbus_root_path/interfaces/kits/bus_center",
    ]
    external_deps += [
      "napi:ace_napi"
    ]
    sources += [
      "$dsoftbus_sdk_path/napi/agent_communication/virtual/napi_agent_communication_virtual.cpp",
      "$dsoftbus_sdk_path/napi/agent_communication/virtual/napi_agent_communication_utils_virtual.cpp",
    ]
  }
  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
  }
 
  relative_install_dir = "module/distributedsoftbus"
 
  subsystem_name = "communication"
  part_name = "dsoftbus"
}