dsoftbus_fuzz_common = {
  module_out_path = dsoftbus_fuzz_out_path

  fuzz_config_file = "$dsoftbus_test_path/sdk/frame/fuzztest/softbusclientstub_fuzzer"

  include_dirs = [
    "$dsoftbus_core_path/transmission/common/include",
    "$dsoftbus_sdk_path/frame/standard/include",
    "$dsoftbus_sdk_path/transmission/trans_channel/manager/include/",
    "$dsoftbus_root_path/tests/common/include",
    "$dsoftbus_root_path/core/transmission/common/include",
  ]

  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
    "-fstack-protector-strong",
  ]

  deps = [
    "$dsoftbus_root_path/adapter:softbus_adapter",
    "$dsoftbus_test_path/sdk:softbus_client_static",
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "ipc:ipc_single",
  ]
}

