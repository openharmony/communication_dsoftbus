#####################hydra-fuzz###################
import("//build/test.gni")
import("../../../../../../dsoftbus.gni")
##############################fuzztest##########################################
 
ohos_fuzztest("HandleConversationRegisterListenerFuzzTest") {
  module_out_path = dsoftbus_fuzz_out_path
  fuzz_config_file = "$dsoftbus_root_path/tests/core/bus_center/lnn/fuzztest/handleconversationregisterlistener_fuzzer"
  include_dirs = [
    "$dsoftbus_root_path/core/bus_center/extend/include",
    "$dsoftbus_root_path/core/frame/standard/init/include",
    "$dsoftbus_root_path/interfaces/kits/common",
    "$dsoftbus_root_path/interfaces/kits/connection",
    "$dsoftbus_root_path/interfaces/kits/bus_center/",
    "$dsoftbus_root_path/interfaces/kits/bus_center/enhance",
    "$dsoftbus_root_path/interfaces/kits/disc",
    "$dsoftbus_root_path/interfaces/kits/transport",
    "$dsoftbus_root_path/interfaces/inner_kits/transport",
    "$dsoftbus_root_path/core/bus_center/interface",
    "$dsoftbus_root_path/core/transmission/common/include",
    "$dsoftbus_root_path/core/discovery/manager/include",
    "$dsoftbus_root_path/core/discovery/interface",
    "$dsoftbus_root_path/tests/common/include",
    "$dsoftbus_root_path/tests/sdk/common/include",
  ]
 
  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]
 
  sources = [
    "handleconversationregisterlistener_fuzzer.cpp",
  ]
 
  deps = [
    "$dsoftbus_root_path/adapter:softbus_adapter",
    "$dsoftbus_root_path/core/frame:softbus_server",
    "$dsoftbus_root_path/tests/sdk/common:softbus_access_token_test",
  ]
 
  external_deps = [
    "access_token:libaccesstoken_sdk",
    "c_utils:utils",
    "ipc:ipc_single",
    "safwk:system_ability_fwk",
    "samgr:samgr_proxy",
  ]
}