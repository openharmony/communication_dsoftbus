{"KEY_GC_IP":"192.168.1.100"}
{"KEY_INTERFACE_NAME":"wlan0"}
{"KEY_CHANNEL_LIST":"1 6 11"}
{"KEY_STATION_FREQUENCY":2412}
{"KEY_WIDE_BAND_SUPPORTED":false}
{"KEY_COMMAND_TYPE":1}

# ========== 正负数测试 ==========
{"largeNumber":2147483647}
{"negativeNumber":-2147483648}
{"unsignedNumber":4294967295}

# ========== 渐进式增加字段数量 ==========
{"a":1,"b":2}
{"a":1,"b":2,"c":3}
{"a":1,"b":2,"c":3,"d":4}
