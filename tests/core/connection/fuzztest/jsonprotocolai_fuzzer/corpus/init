# JSON Protocol Fuzzer Seeds - 覆盖 SetInput/Read/外部数据解析
# 聚焦于测试外部不可信数据的解析和读取

# ========== 基本有效 JSON ==========
{"KEY_VERSION":1}
{"KEY_ROLE":0}
{"test":true,"value":123}
{"KEY_IP":"192.168.1.1","KEY_PORT":8080}
{"a":1,"b":2,"c":3}
{"string":"hello","bool":true}

# ========== 错误格式 JSON ==========
invalid{"json":data
KEY_VERSION
{"test":true,"number":123456789}

# ========== 边界长度测试 ==========
{"num1":0,"num2":255,"num3":256}
{"max":65535,"min":-65535}
{"level":0,"flag":1,"status":2}

# ========== 空对象/最小 JSON ==========
{}
{"":""}
{"a":1}
{"multiple":"keys","here":true,"test":123}

